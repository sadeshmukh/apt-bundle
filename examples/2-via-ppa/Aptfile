# PHP from PPA (Ondrej's PHP PPA)
# PPAs automatically handle GPG keys - no need for 'key' directive!
ppa ppa:ondrej/php
apt php8.2
apt php8.2-cli
apt php8.2-fpm

# Git from PPA (newer versions than Ubuntu repos)
ppa ppa:git-core/ppa
apt git

# Development tools from standard repos
apt build-essential
apt curl
apt vim

