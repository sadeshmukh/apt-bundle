FROM ubuntu:22.04

# Prevent interactive prompts during apt operations
ENV DEBIAN_FRONTEND=noninteractive

# Install all packages manually
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        git \
        jq && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Your application code
WORKDIR /app
COPY . /app
CMD ["/bin/bash"]

