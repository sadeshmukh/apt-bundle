FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install build tools and utilities manually
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        git \
        jq && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /workspace

# Default command for CI
CMD ["/bin/bash"]

